name: Build Nothing OS 4.1 Kernel (SUSFS)

on:
  workflow_dispatch:
  push:
    branches:
      - main

permissions:
  contents: read

jobs:
  build-kernel:
    runs-on: ubuntu-latest
    steps:
      - name: 1. Maximize Build Space
        uses: easimon/maximize-build-space@master
        with:
          root-reserve-mb: 8192
          swap-size-mb: 8192
          remove-dotnet: 'true'
          remove-android: 'true'
          remove-haskell: 'true'

      - name: 2. Install Build Dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y build-essential bc curl git python3 python-is-python3 libssl-dev repo flex bison zip unzip

      - name: 3. Setup Kleaf / Bazel Build Workspace Environment
        run: |
          mkdir -p workspace
          cd workspace
          echo ">> Initializing Android 6.6 Kernel Manifest wrapper..."
          repo init -u https://android.googlesource.com/kernel/manifest -b common-android15-6.6 --depth=1

          echo ">> Syncing manifest environment..."
          repo sync -c -j$(nproc) --no-tags --no-clone-bundle

          echo ">> Constructing Kleaf workspace configuration..."
          if [ -f build/kernel/kleaf/bazel.WORKSPACE ]; then
            TARGET_WS="build/kernel/kleaf/bazel.WORKSPACE"
          elif [ -f build/kernel/kleaf/WORKSPACE ]; then
            TARGET_WS="build/kernel/kleaf/WORKSPACE"
          else
            echo ">> [FATAL] Kleaf Workspace template not found!" && exit 1
          fi

          if [ -f build/kernel/kleaf/bzlmod/bazel.MODULE.bazel ]; then
            TARGET_MOD="build/kernel/kleaf/bzlmod/bazel.MODULE.bazel"
          fi

          rm -f WORKSPACE MODULE.bazel

          cp "$TARGET_WS" WORKSPACE
          chmod +w WORKSPACE
          echo 'local_repository(name = "nt_project", path = "nt_project")' >> WORKSPACE

          if [ -n "$TARGET_MOD" ]; then
            cp "$TARGET_MOD" MODULE.bazel
            chmod +w MODULE.bazel
            echo 'bazel_dep(name = "nt_project")' >> MODULE.bazel
            echo 'local_path_override(module_name = "nt_project", path = "nt_project")' >> MODULE.bazel
          fi

          mkdir -p tools
          ln -sf ../build/kernel/kleaf/bazel.sh tools/bazel

      - name: 4. Checkout Nothing Kernel Source (NOS 4.1)
        uses: actions/checkout@v4
        with:
          repository: NothingOSS/android_kernel_msm-6.6_nothing_sm8735
          ref: sm8735/b/mr
          path: workspace/msm-kernel

      - name: 5. Inject KernelSU-Next & SUSFS
        working-directory: workspace/msm-kernel
        run: |
          echo ">> Downloading KernelSU-Next..."
          curl -LSs "https://raw.githubusercontent.com/KernelSU-Next/KernelSU-Next/next/kernel/setup.sh" | bash -

          echo ">> Downloading SUSFS patches..."
          git clone https://gitlab.com/simonpunk/susfs4ksu.git -b gki-android15-6.6 /tmp/susfs4ksu

          echo ">> Dumping susfs4ksu repo structure for diagnostics..."
          find /tmp/susfs4ksu -type f | sort

          echo ">> Applying SUSFS core source files to kernel..."
          cp -r /tmp/susfs4ksu/kernel_patches/fs/* fs/
          cp -r /tmp/susfs4ksu/kernel_patches/include/linux/* include/linux/

          if ! grep -q "susfs.o" fs/Makefile; then
            echo "obj-y += susfs.o" >> fs/Makefile
            echo "CFLAGS_susfs.o += -Wno-unused-variable -Wno-unused-function -Wno-error" >> fs/Makefile
          fi

          echo ">> Applying SUSFS GKI VFS patch..."
          SUSFS_KERNEL_PATCH=$(find /tmp/susfs4ksu -type f -name "*.patch" | grep -i "gki" | head -n 1)
          if [ -n "$SUSFS_KERNEL_PATCH" ]; then
            echo ">> Applying GKI patch: $SUSFS_KERNEL_PATCH"
            patch -p1 --fuzz=3 < "$SUSFS_KERNEL_PATCH" || true
          else
            echo ">> [WARN] No GKI patch found, skipping."
          fi

          echo ">> Locating KernelSU-Next root directory..."
          KSU_ROOT=$(find . -maxdepth 1 -type d -name "KernelSU*" | head -n 1)

          if [ -z "$KSU_ROOT" ] && [ -L drivers/kernelsu ]; then
            KSU_ROOT=$(dirname "$(readlink -f drivers/kernelsu)")
          fi

          if [ -z "$KSU_ROOT" ]; then
            echo "[FATAL] Could not locate KernelSU-Next root directory!" && exit 1
          fi

          echo ">> KernelSU-Next root resolved to: $KSU_ROOT"

          echo ">> Searching for KSU SUSFS patch..."
          PATCH_FILE=$(find /tmp/susfs4ksu -type f -name "*.patch" | grep -i "ksunext" | head -n 1)

          if [ -z "$PATCH_FILE" ]; then
            PATCH_FILE=$(find /tmp/susfs4ksu -type f -name "*.patch" | grep -v "gki" | head -n 1)
          fi

          if [ -z "$PATCH_FILE" ]; then
            echo "[FATAL] Could not find any KSU SUSFS patch in susfs4ksu repo!"
            echo "Available patches:"
            find /tmp/susfs4ksu -type f -name "*.patch"
            exit 1
          fi

          echo ">> Applying KSU patch from $KSU_ROOT: $PATCH_FILE"
          (cd "$KSU_ROOT" && patch -p1 --fuzz=3 < "$PATCH_FILE")

          if ! grep -rq "susfs_is_current_ksu_domain" "$KSU_ROOT"; then
            echo "[FATAL] Patch did not introduce susfs_is_current_ksu_domain — patch likely failed."
            exit 1
          fi
          echo ">> KSU SUSFS patch verified OK."

          if [ -d drivers/kernelsu ] && ! grep -q "kernelsu" drivers/Kconfig; then
            sed -i '/endmenu/i source "drivers/kernelsu/Kconfig"' drivers/Kconfig
          fi

          echo ">> Neutralizing fingerprint module..."
          if [ -d drivers/input/fingerprint ]; then
            echo "obj-y =" > drivers/input/fingerprint/Makefile
          fi

          echo ">> Injecting KSU and SUSFS config flags into defconfigs..."
          find arch/arm64/configs/ -type f \( -name "*_defconfig" -o -name "*.config" -o -name "*.fragment" \) \
            -exec sh -c '
              echo "CONFIG_KSU=y" >> "$1"
              echo "CONFIG_KSU_SUSFS=y" >> "$1"
              echo "CONFIG_KSU_SUSFS_SUS_PATH=y" >> "$1"
              echo "CONFIG_KSU_SUSFS_SUS_MOUNT=y" >> "$1"
              echo "CONFIG_KSU_SUSFS_SUS_KSTAT=y" >> "$1"
              echo "CONFIG_KSU_SUSFS_TRY_UMOUNT=y" >> "$1"
              echo "CONFIG_KSU_SUSFS_SPOOFER=y" >> "$1"
              echo "CONFIG_KSU_SUSFS_ENABLE_LOG=y" >> "$1"
              echo "CONFIG_KSU_SUSFS_OPEN_REDIRECT=y" >> "$1"
            ' _ {} \;

      - name: 6. Prepare Qualcomm Build Package Extensions
        working-directory: workspace
        run: |
          mkdir -p build
          touch build/BUILD.bazel
          if [ -f msm-kernel/msm_kernel_extensions.bzl ]; then
            cp msm-kernel/msm_kernel_extensions.bzl build/
          elif [ -f msm-kernel/build/msm_kernel_extensions.bzl ]; then
            cp msm-kernel/build/msm_kernel_extensions.bzl build/
          else
            echo "def define_top_level_rules(): pass" > build/msm_kernel_extensions.bzl
            echo "def define_extras(*args, **kwargs): pass" >> build/msm_kernel_extensions.bzl
            echo "def get_build_config_fragments(*args, **kwargs): return []" >> build/msm_kernel_extensions.bzl
            echo "def get_dtb_list(*args, **kwargs): return []" >> build/msm_kernel_extensions.bzl
            echo "def get_dtbo_list(*args, **kwargs): return []" >> build/msm_kernel_extensions.bzl
            echo "def get_dtstree(*args, **kwargs): return \"\"" >> build/msm_kernel_extensions.bzl
            echo "def get_gki_ramdisk_prebuilt_binary(*args, **kwargs): return \"\"" >> build/msm_kernel_extensions.bzl
            echo "def get_vendor_ramdisk_binaries(*args, **kwargs): return []" >> build/msm_kernel_extensions.bzl
            echo "def define_combined_vm_image(*args, **kwargs): pass" >> build/msm_kernel_extensions.bzl
          fi

      - name: 7. Sanitize Obsolete Parameters & Mock OEM Layers
        working-directory: workspace
        shell: python
        run: |
          import os
          import re

          def remove_attribute(content, attr_name):
              pattern = r'\b' + attr_name + r'\s*=\s*'
              while True:
                  match = re.search(pattern, content)
                  if not match:
                      break
                  start_idx = match.start()
                  end_idx = match.end()
                  bracket_count = 0
                  paren_count = 0
                  brace_count = 0
                  while end_idx < len(content):
                      char = content[end_idx]
                      if char == '(': paren_count += 1
                      elif char == ')': paren_count -= 1
                      elif char == '[': bracket_count += 1
                      elif char == ']': bracket_count -= 1
                      elif char == '{': brace_count += 1
                      elif char == '}': brace_count -= 1
                      elif char == ',' and bracket_count == 0 and paren_count == 0 and brace_count == 0:
                          end_idx += 1
                          break
                      elif char == '\n' and bracket_count == 0 and paren_count == 0 and brace_count == 0:
                          break
                      end_idx += 1
                  content = content[:start_idx] + content[end_idx:]
              return content

          os.makedirs("nt_project", exist_ok=True)
          with open("nt_project/BUILD.bazel", "w") as f: f.write("")
          with open("nt_project/MODULE.bazel", "w") as f: f.write('module(name = "nt_project")\n')

          symbols = {}

          for root, dirs, files in os.walk("build/kernel"):
              for file in files:
                  if file.endswith((".sh", ".py", ".bzl", ".bsh", ".gki")):
                      p = os.path.join(root, file)
                      try:
                          with open(p, "r", encoding="utf-8", errors="ignore") as f:
                              content = f.read()
                          mutated = False
                          if "check_defconfig" in content:
                              content = re.sub(r'check_defconfig\s*\(\s*\)\s*\{', 'check_defconfig() {\n  return 0\n', content)
                              content = content.replace('POST_DEFCONFIG_CMDS="check_defconfig"', 'POST_DEFCONFIG_CMDS=""')
                              content = content.replace('POST_DEFCONFIG_CMDS=\\"check_defconfig\\"', 'POST_DEFCONFIG_CMDS=\\"\\"')
                              mutated = True
                          if "savedefconfig does not match" in content:
                              content = content.replace("return ${RES}", "return 0")
                              content = content.replace("return $RES", "return 0")
                              content = content.replace("exit ${RES}", "exit 0")
                              content = content.replace("exit $RES", "exit 0")
                              mutated = True
                          if mutated:
                              print(f"[*] Neutralized defconfig validation in: {p}")
                              with open(p, "w", encoding="utf-8") as f:
                                  f.write(content)
                      except Exception as e:
                          print(f"File patching error: {e}")

          for root, dirs, files in os.walk("msm-kernel"):
              for file in files:
                  if file.endswith(".bzl") or file in ["BUILD", "BUILD.bazel"]:
                      fn = os.path.join(root, file)
                      try:
                          with open(fn, "r", encoding="utf-8", errors="ignore") as f:
                              content = f.read()
                          mutated = False
                          if "gki_ramdisk_prebuilt_binary" in content:
                              content = remove_attribute(content, "gki_ramdisk_prebuilt_binary")
                              mutated = True
                          if "nt_project" in content:
                              matches = re.findall(r"load\s*\(\s*[\"\']@nt_project//:dict\.bzl[\"\']\s*,\s*([^)]+)\)", content)
                              for match in matches:
                                  for part in match.split(","):
                                      part = part.strip()
                                      if not part: continue
                                      if "=" in part:
                                          sym = part.split("=")[1].strip().strip('"').strip("'")
                                      else:
                                          sym = part.strip("\"").strip("'")
                                      if sym:
                                          if "module" in sym.lower() or "out" in sym.lower() or "+" in content:
                                              symbols[sym] = "[]"
                                          else:
                                              symbols[sym] = '{"metroid": {}, "sun": {}, "pacman": {}, "pong": {}, "spock": {}, "default": {}}'
                          if mutated:
                              with open(fn, "w", encoding="utf-8") as f:
                                  f.write(content)
                      except Exception as e:
                          print(f"[!] Error processing {fn}: {e}")

          with open("nt_project/dict.bzl", "w") as f:
              for sym, val in symbols.items():
                  f.write(f"{sym} = {val}\n")

      - name: 8. Compile the Kernel via Qualcomm Kleaf
        working-directory: workspace
        run: |
          echo ">> Commencing Kernel Compilation via Qualcomm Bazel..."
          tools/bazel run //msm-kernel:kernel_aarch64_dist -- --dist_dir=out_dist

      - name: 9. Upload Boot Image
        uses: actions/upload-artifact@v4
        with:
          name: boot-img-nos4.1-susfs
          path: workspace/out_dist/boot.img
          compression-level: 9
